\citation{sukhbaatar2024branchtrainmix}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {\textsc  {Kalavai}\xspace  core results.} \textbf  {(A)} Fusion improvement over the best individual specialist across model scales: +14.2\% at 410M, +14.8\% at 1B, +2.4\% at 6.9B. \textbf  {(B)} Training duration crossover: freeze=0 peaks at 5k steps then degrades; freeze=4 plateaus through 20k steps; crossover at $\approx $10k steps. \textbf  {(C)} Routing failure modes: learned MoE routing achieves +14.1\%; single-specialist classifier dispatch degrades by $-$21.1\% (negative values indicate degradation below base). \textbf  {(D)} \textsc  {Kalavai}\xspace  vs.\ equal-compute alternatives at 410M: MoE achieves +14.5\% over the equal-compute monolithic baseline. All results are means over 3 seeds.}}{6}{figure.caption.27}\protected@file@percent }
\newlabel{fig:hero}{{1}{6}{\textbf {\kalavai core results.} \textbf {(A)} Fusion improvement over the best individual specialist across model scales: +14.2\% at 410M, +14.8\% at 1B, +2.4\% at 6.9B. \textbf {(B)} Training duration crossover: freeze=0 peaks at 5k steps then degrades; freeze=4 plateaus through 20k steps; crossover at $\approx $10k steps. \textbf {(C)} Routing failure modes: learned MoE routing achieves +14.1\%; single-specialist classifier dispatch degrades by $-$21.1\% (negative values indicate degradation below base). \textbf {(D)} \kalavai vs.\ equal-compute alternatives at 410M: MoE achieves +14.5\% over the equal-compute monolithic baseline. All results are means over 3 seeds}{figure.caption.27}{}}
